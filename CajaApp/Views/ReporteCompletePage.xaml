<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CajaApp.Views.ReporteCompletePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:CajaApp.Helpers;assembly=Sellik"
    Title="{loc:Translate Reporte_Titulo}"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollView Grid.Row="0" Padding="20">
            <Label
                x:Name="ReporteLabel"
                FontFamily="Courier"
                FontSize="12"
                LineBreakMode="NoWrap"
                TextColor="{DynamicResource TextColor}" />
        </ScrollView>

        <StackLayout
            Grid.Row="1"
            Margin="10"
            Orientation="Horizontal"
            Spacing="10">
            <Button
                x:Name="CompartirReporteButton"
                BackgroundColor="#4CAF50"
                Clicked="OnCompartirReporteClicked"
                CornerRadius="10"
                HorizontalOptions="Fill"
                Text="{loc:Translate Btn_Compartir}"
                TextColor="White" />

            <Button
                x:Name="CerrarButton"
                BackgroundColor="#F44336"
                Clicked="OnCerrarClicked"
                CornerRadius="10"
                HorizontalOptions="Fill"
                Text="{loc:Translate Btn_Cerrar}"
                TextColor="White" />
        </StackLayout>
    </Grid>
</ContentPage>