<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CajaApp.Views.NotasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CajaApp.ViewModels"
    xmlns:models="clr-namespace:CajaApp.Models"
    xmlns:loc="clr-namespace:CajaApp.Helpers;assembly=Sellik"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    x:DataType="vm:NotasViewModel"
    Title="{loc:Translate Notas_Titulo}"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header con estadísticas  -->
        <Border
            Grid.Row="0"
            Margin="10,10,10,5"
            Background="#9C27B0"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalOptions="Center"
                        Text="{loc:Translate Notas_Total}"
                        TextColor="White" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="{Binding TotalNotas}"
                        TextColor="White" />
                </StackLayout>

                <StackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalOptions="Center"
                        Text="{loc:Translate Notas_ConImagen}"
                        TextColor="White" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="{Binding NotasConImagen}"
                        TextColor="#C8E6C9" />
                </StackLayout>

                <StackLayout Grid.Column="2" HorizontalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalOptions="Center"
                        Text="{loc:Translate Notas_Favoritas}"
                        TextColor="White" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="{Binding NotasFavoritas}"
                        TextColor="#FFE082" />
                </StackLayout>
            </Grid>
        </Border>

        <!--  Botones de nueva nota  -->
        <Border
            Grid.Row="1"
            Margin="10,5"
            Background="{DynamicResource SurfaceColor}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 10">
            <StackLayout HorizontalOptions="Fill" Orientation="Horizontal">
                <Button
                    x:Name="NuevaNotaTextoButton"
                    BackgroundColor="#2196F3"
                    Clicked="OnNuevaNotaTextoClicked"
                    CornerRadius="10"
                    FontSize="14"
                    HorizontalOptions="Fill"
                    Text="{loc:Translate Notas_BtnTexto}"
                    TextColor="White" />

                <Button
                    x:Name="NuevaNotaImagenButton"
                    Margin="5,0"
                    BackgroundColor="#4CAF50"
                    Clicked="OnNuevaNotaImagenClicked"
                    CornerRadius="10"
                    FontSize="14"
                    HorizontalOptions="Fill"
                    Text="{loc:Translate Notas_BtnFoto}"
                    TextColor="White" />

                <Button
                    x:Name="NuevaNotaMixtaButton"
                    BackgroundColor="#FF9800"
                    Clicked="OnNuevaNotaMixtaClicked"
                    CornerRadius="10"
                    FontSize="14"
                    HorizontalOptions="Fill"
                    Text="{loc:Translate Notas_BtnMixta}"
                    TextColor="White" />
            </StackLayout>
        </Border>

        <!--  Filtros  -->
        <Border
            Grid.Row="2"
            Margin="10,5"
            Background="{DynamicResource SurfaceColor}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <SearchBar
                    x:Name="BuscarEntry"
                    Grid.Row="0"
                    Placeholder="{loc:Translate Notas_BuscarPlaceholder}"
                    SearchButtonPressed="OnBuscarPressed"
                    Text="{Binding FiltroTexto}"
                    TextChanged="OnBuscarTextChanged" />

                <StackLayout
                    Grid.Row="1"
                    Margin="0,5,0,0"
                    Orientation="Horizontal">
                    <Picker
                        x:Name="FiltroTipoPicker"
                        Title="{loc:Translate Notas_FiltroTipo}"
                        FontSize="12"
                        HorizontalOptions="Fill"
                        SelectedIndexChanged="OnFiltroTipoChanged" />

                    <CheckBox
                        x:Name="FavoritasCheckBox"
                        IsChecked="{Binding SoloFavoritas}"
                        Color="#FF9800" />
                    <Label
                        FontSize="12"
                        Text="{loc:Translate Notas_FiltroFavoritas}"
                        VerticalOptions="Center" />

                    <Button
                        x:Name="LimpiarFiltrosButton"
                        BackgroundColor="Transparent"
                        Clicked="OnLimpiarFiltrosClicked"
                        FontSize="12"
                        Text="✖" />
                </StackLayout>
            </Grid>
        </Border>

        <!--  Filtros de fecha  -->
        <ScrollView
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalScrollBarVisibility="Never"
            Margin="10,0,10,4">
            <HorizontalStackLayout Spacing="4" Padding="0,6">
                <Button x:Name="BtnFechaTodas"
                        Style="{StaticResource FilterChipActive}"
                        Text="{loc:Translate Notas_FiltroFechaTodas}"
                        Clicked="OnFiltroFechaClicked"
                        CommandParameter="0" />
                <Button x:Name="BtnFechaHoy"
                        Style="{StaticResource FilterChipInactive}"
                        Text="{loc:Translate Notas_FiltroFechaHoy}"
                        Clicked="OnFiltroFechaClicked"
                        CommandParameter="1" />
                <Button x:Name="BtnFechaSemana"
                        Style="{StaticResource FilterChipInactive}"
                        Text="{loc:Translate Notas_FiltroFechaSemana}"
                        Clicked="OnFiltroFechaClicked"
                        CommandParameter="2" />
                <Button x:Name="BtnFechaMes"
                        Style="{StaticResource FilterChipInactive}"
                        Text="{loc:Translate Notas_FiltroFechaMes}"
                        Clicked="OnFiltroFechaClicked"
                        CommandParameter="3" />
                <Button x:Name="BtnFechaAnio"
                        Style="{StaticResource FilterChipInactive}"
                        Text="{loc:Translate Notas_FiltroFechaAnio}"
                        Clicked="OnFiltroFechaClicked"
                        CommandParameter="4" />

                <BoxView WidthRequest="1" HeightRequest="24" Color="{DynamicResource BorderColor}" VerticalOptions="Center" Margin="4,0" />

                <DatePicker x:Name="FechaEspecificaPicker"
                            Format="dd/MM/yy"
                            FontSize="12"
                            HeightRequest="34"
                            VerticalOptions="Center"
                            DateSelected="OnFechaEspecificaSelected" />
            </HorizontalStackLayout>
        </ScrollView>

        <!--  Lista de notas  -->
        <CollectionView
            x:Name="NotasCollectionView"
            Grid.Row="4"
            Margin="10,5"
            ItemsSource="{Binding NotasFiltradas}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Nota">
                    <Border
                        Margin="5"
                        Padding="10"
                        BackgroundColor="{DynamicResource CardColor}"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label
                                    Grid.Column="0"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding Titulo}" />

                                <Label
                                    Grid.Column="1"
                                    FontSize="11"
                                    Text="{Binding FechaTexto}"
                                    TextColor="Gray" />
                            </Grid>

                            <Label
                                Grid.Row="1"
                                Margin="0,5"
                                FontSize="13"
                                Text="{Binding ResumenContenido}"
                                TextColor="Gray" />

                            <StackLayout
                                Grid.Row="2"
                                HorizontalOptions="End"
                                Orientation="Horizontal">
                                <Button
                                    BackgroundColor="Transparent"
                                    Clicked="OnVerNotaClicked"
                                    CommandParameter="{Binding .}"
                                    FontSize="14"
                                    Text="👁️" />
                                <Button
                                    BackgroundColor="Transparent"
                                    Clicked="OnEditarNotaClicked"
                                    CommandParameter="{Binding .}"
                                    FontSize="14"
                                    Text="✏️" />
                                <Button
                                    BackgroundColor="Transparent"
                                    Clicked="OnToggleFavoritaClicked"
                                    CommandParameter="{Binding .}"
                                    FontSize="14"
                                    Text="{Binding IconoFavorita}" />
                                <Button
                                    BackgroundColor="Transparent"
                                    Clicked="OnEliminarNotaClicked"
                                    CommandParameter="{Binding .}"
                                    FontSize="14"
                                    Text="🗑️" />
                            </StackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <StackLayout
                    Padding="50"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <Label
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="📝" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="{loc:Translate Notas_EmptyTitle}"
                        TextColor="Gray" />
                </StackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!--  Botones de acción  -->
        <StackLayout
            Grid.Row="5"
            Margin="10,5,10,20"
            HorizontalOptions="Fill"
            Orientation="Horizontal">
            <Button
                x:Name="ExportarButton"
                BackgroundColor="#607D8B"
                Clicked="OnExportarClicked"
                CornerRadius="10"
                HorizontalOptions="Fill"
                Text="📤"
                TextColor="White" />

            <Button
                x:Name="ReporteButton"
                Margin="10,0"
                BackgroundColor="#2196F3"
                Clicked="OnGenerarReporteClicked"
                CornerRadius="10"
                HorizontalOptions="Fill"
                Text="📊"
                TextColor="White" />

            <Button
                x:Name="CompartirButton"
                BackgroundColor="#4CAF50"
                Clicked="OnCompartirClicked"
                CornerRadius="10"
                HorizontalOptions="Fill"
                Text="📱"
                TextColor="White" />
        </StackLayout>

    </Grid>
</ContentPage>