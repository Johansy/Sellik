<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CajaApp.Views.EstadisticasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:CajaApp.Helpers;assembly=Sellik"
    xmlns:vm="clr-namespace:CajaApp.ViewModels"
    x:DataType="vm:EstadisticasViewModel"
    Title="{loc:Translate Estadisticas_Titulo}"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <ScrollView Padding="16">
        <StackLayout Spacing="12">

            <!--  Header  -->
            <Border
                Padding="16,12"
                Background="{DynamicResource PrimaryColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <Label
                        Grid.Row="0" Grid.Column="0"
                        FontAttributes="Bold"
                            FontSize="18"
                            Text="{loc:Translate Estadisticas_Header}"
                            TextColor="White" />
                    <ActivityIndicator
                        Grid.Row="0" Grid.Column="1"
                        Color="White"
                        IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        WidthRequest="22" HeightRequest="22" />
                    <Label
                        Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        FontSize="12"
                        Opacity="0.85"
                        Text="{Binding PeriodoTexto}"
                        TextColor="White" />
                </Grid>
            </Border>

            <!--  Selector de período  -->
            <Border
                Padding="14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_Periodo}"
                        TextColor="{DynamicResource PrimaryColor}" />
                    <Picker
                        ItemsSource="{Binding OpcionesPeriodo}"
                        SelectedItem="{Binding PeriodoSeleccionado}"
                        TextColor="{DynamicResource TextColor}"
                        SelectedIndexChanged="OnPeriodoChanged" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <StackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{loc:Translate Estadisticas_Desde}" FontSize="11" TextColor="{DynamicResource TextColor}" Opacity="0.6" />
                            <DatePicker Date="{Binding FechaInicio}" TextColor="{DynamicResource TextColor}" />
                        </StackLayout>
                        <StackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{loc:Translate Estadisticas_Hasta}" FontSize="11" TextColor="{DynamicResource TextColor}" Opacity="0.6" />
                            <DatePicker Date="{Binding FechaFin}" TextColor="{DynamicResource TextColor}" />
                        </StackLayout>
                    </Grid>
                    <Button
                        Command="{Binding CargarCommand}"
                        BackgroundColor="{DynamicResource PrimaryColor}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        Text="{loc:Translate Estadisticas_Actualizar}"
                        TextColor="White"
                        HeightRequest="40" />
                </StackLayout>
            </Border>

            <!--  Ganancia acumulada estimada  -->
            <Border
                Padding="16,14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="1.5"
                Stroke="{DynamicResource PrimaryColor}"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_GananciaHeader}"
                        TextColor="{DynamicResource PrimaryColor}" />

                    <BoxView HeightRequest="1" Color="{DynamicResource PrimaryColor}" Opacity="0.15" />

                    <!--  Desglose de la fórmula  -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{loc:Translate Estadisticas_UltimoArqueo}"
                               TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding UltimoTotalCajaTexto}"
                               FontAttributes="Bold" FontSize="13"
                               TextColor="#2E7D32" HorizontalOptions="End" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{loc:Translate Estadisticas_TotalVouchersLabel}"
                               TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding TotalVouchersTexto}"
                               FontAttributes="Bold" FontSize="13"
                               TextColor="#673AB7" HorizontalOptions="End" />

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="{loc:Translate Estadisticas_SaldoMovLabel}"
                               TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding SaldoMovimientosTexto}"
                               FontAttributes="Bold" FontSize="13"
                               TextColor="#FF9800" HorizontalOptions="End" />

                        <BoxView Grid.Row="3" Grid.ColumnSpan="2"
                                 HeightRequest="1" Color="{DynamicResource PrimaryColor}" Opacity="0.25" />

                        <Label Grid.Row="4" Grid.Column="0"
                               Text="{loc:Translate Estadisticas_GananciaTotal}"
                               FontAttributes="Bold" FontSize="15"
                               TextColor="{DynamicResource PrimaryColor}" />
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="{Binding GananciaAcumuladaTexto}"
                               FontAttributes="Bold" FontSize="17"
                               TextColor="{DynamicResource PrimaryColor}" HorizontalOptions="End" />
                    </Grid>

                    <Label
                        FontSize="11"
                        Opacity="0.55"
                        Text="{loc:Translate Estadisticas_GananciaTooltip}"
                        TextColor="{DynamicResource TextColor}" />
                </StackLayout>
            </Border>

            <!--  Actividad principal  -->
            <Border
                Padding="14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_ActividadPrincipal}"
                        TextColor="{DynamicResource PrimaryColor}" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="{Binding ActividadPrincipal}"
                        TextColor="{DynamicResource TextColor}" />

                    <!--  Barras comparativas  -->
                    <Grid ColumnDefinitions="100,*,50" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="{loc:Translate Estadisticas_Cajas}" TextColor="{DynamicResource TextColor}" FontSize="13" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="0" Grid.Column="1" Progress="{Binding ProgressCajas}" ProgressColor="#2E7D32" VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="2" Text="{Binding TotalCajas}" TextColor="{DynamicResource TextColor}" FontSize="13" HorizontalOptions="End" VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0" Text="{loc:Translate Estadisticas_Movimientos}" TextColor="{DynamicResource TextColor}" FontSize="13" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="1" Grid.Column="1" Progress="{Binding ProgressMovimientos}" ProgressColor="#FF9800" VerticalOptions="Center" />
                        <Label Grid.Row="1" Grid.Column="2" Text="{Binding TotalMovimientos}" TextColor="{DynamicResource TextColor}" FontSize="13" HorizontalOptions="End" VerticalOptions="Center" />

                        <Label Grid.Row="2" Grid.Column="0" Text="{loc:Translate Estadisticas_Vouchers}" TextColor="{DynamicResource TextColor}" FontSize="13" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="2" Grid.Column="1" Progress="{Binding ProgressVouchers}" ProgressColor="#673AB7" VerticalOptions="Center" />
                        <Label Grid.Row="2" Grid.Column="2" Text="{Binding TotalVouchers}" TextColor="{DynamicResource TextColor}" FontSize="13" HorizontalOptions="End" VerticalOptions="Center" />

                        <Label Grid.Row="3" Grid.Column="0" Text="{loc:Translate Estadisticas_Notas}" TextColor="{DynamicResource TextColor}" FontSize="13" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="3" Grid.Column="1" Progress="{Binding ProgressNotas}" ProgressColor="#9C27B0" VerticalOptions="Center" />
                        <Label Grid.Row="3" Grid.Column="2" Text="{Binding TotalNotas}" TextColor="{DynamicResource TextColor}" FontSize="13" HorizontalOptions="End" VerticalOptions="Center" />
                    </Grid>
                </StackLayout>
            </Border>

            <!--  ═══════════  ARQUEOS DE CAJA  ═══════════  -->
            <Border
                Padding="14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_ArqueosHeader}"
                        TextColor="#2E7D32" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="{loc:Translate Estadisticas_ArqueosRegistrados}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalCajas}" FontAttributes="Bold" FontSize="15" TextColor="#2E7D32" HorizontalOptions="End" />

                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="{DynamicResource PrimaryColor}" Opacity="0.15" />

                        <Label Grid.Row="2" Grid.Column="0" Text="{loc:Translate Estadisticas_TotalContado}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TotalDineroTexto}" FontAttributes="Bold" FontSize="14" TextColor="#2E7D32" HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0" Text="{loc:Translate Estadisticas_PromedioPorArqueo}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding PromedioArqueoTexto}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="4" Grid.Column="0" Text="{loc:Translate Estadisticas_MaximoMinimo}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="4" Grid.Column="1" FontSize="12" HorizontalOptions="End" TextColor="{DynamicResource TextColor}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding ArqueoMaximoTexto}" TextColor="#2E7D32" />
                                    <Span Text=" / " />
                                    <Span Text="{Binding ArqueoMinimoTexto}" TextColor="#F44336" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>
                </StackLayout>
            </Border>

            <!--  ═══════════  MOVIMIENTOS  ═══════════  -->
            <Border
                Padding="14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_MovimientosHeader}"
                        TextColor="#FF9800" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="{loc:Translate Estadisticas_TotalMovimientos}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalMovimientos}" FontAttributes="Bold" FontSize="15" TextColor="#FF9800" HorizontalOptions="End" />

                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="{DynamicResource PrimaryColor}" Opacity="0.15" />

                        <Label Grid.Row="2" Grid.Column="0" Text="{loc:Translate Estadisticas_Entradas}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TotalEntradasTexto}" FontAttributes="Bold" FontSize="14" TextColor="#4CAF50" HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0" Text="{loc:Translate Estadisticas_Salidas}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TotalSalidasTexto}" FontAttributes="Bold" FontSize="14" TextColor="#F44336" HorizontalOptions="End" />

                        <Label Grid.Row="4" Grid.Column="0" Text="{loc:Translate Estadisticas_SaldoNeto}" FontAttributes="Bold" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding SaldoMovimientosTexto}" FontAttributes="Bold" FontSize="14" TextColor="#FF9800" HorizontalOptions="End" />
                    </Grid>
                </StackLayout>
            </Border>

            <!--  ═══════════  VOUCHERS  ═══════════  -->
            <Border
                Padding="14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_VouchersHeader}"
                        TextColor="#673AB7" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="{loc:Translate Estadisticas_TotalEscaneados}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalVouchers}" FontAttributes="Bold" FontSize="15" TextColor="#673AB7" HorizontalOptions="End" />

                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="{DynamicResource PrimaryColor}" Opacity="0.15" />

                        <Label Grid.Row="2" Grid.Column="0" Text="{loc:Translate Estadisticas_ImporteTotal}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TotalVouchersTexto}" FontAttributes="Bold" FontSize="14" TextColor="#673AB7" HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0" Text="{loc:Translate Estadisticas_Credito}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding VouchersCredito}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="4" Grid.Column="0" Text="{loc:Translate Estadisticas_Debito}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding VouchersDebito}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="5" Grid.Column="0" Text="{loc:Translate Estadisticas_Efectivo}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding VouchersEfectivo}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="6" Grid.Column="0" Text="{loc:Translate Estadisticas_OtrosTipos}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="6" Grid.Column="1" Text="{Binding VouchersOtros}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />
                    </Grid>
                </StackLayout>
            </Border>

            <!--  ═══════════  NOTAS  ═══════════  -->
            <Border
                Margin="0,0,0,16"
                Padding="14"
                Background="{DynamicResource CardColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <StackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="{loc:Translate Estadisticas_NotasHeader}"
                        TextColor="#9C27B0" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="{loc:Translate Estadisticas_TotalNotas}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalNotas}" FontAttributes="Bold" FontSize="15" TextColor="#9C27B0" HorizontalOptions="End" />

                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="{DynamicResource PrimaryColor}" Opacity="0.15" />

                        <Label Grid.Row="2" Grid.Column="0" Text="{loc:Translate Estadisticas_SoloTexto}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding NotasTexto}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0" Text="{loc:Translate Estadisticas_SoloImagen}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding NotasImagen}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="4" Grid.Column="0" Text="{loc:Translate Estadisticas_Mixtas}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding NotasMixtas}" FontSize="13" TextColor="{DynamicResource TextColor}" HorizontalOptions="End" />

                        <Label Grid.Row="5" Grid.Column="0" Text="{loc:Translate Estadisticas_Favoritas}" TextColor="{DynamicResource TextColor}" FontSize="13" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding NotasFavoritas}" FontSize="13" TextColor="#FFD700" HorizontalOptions="End" />
                    </Grid>
                </StackLayout>
            </Border>

        </StackLayout>
    </ScrollView>
</ContentPage>