<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CajaApp.Models"
             xmlns:vm="clr-namespace:CajaApp.ViewModels"
             xmlns:loc="clr-namespace:CajaApp.Helpers;assembly=Sellik"
             x:Class="CajaApp.Views.HistorialPage"
             x:DataType="vm:HistorialViewModel"
             Title="{loc:Translate Historial_Titulo}"
             BackgroundColor="{DynamicResource BackgroundColor}">

  <ContentPage.Content>
    <Grid RowDefinitions="Auto,Auto,Auto,*">

      <!-- Barra de búsqueda -->
      <SearchBar Grid.Row="0"
                 Placeholder="{loc:Translate Notas_BuscarPlaceholder}"
                 Text="{Binding FiltroTexto}"
                 Margin="8,8,8,0" />

      <!-- Filtro de fechas -->
      <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*,Auto"
            Padding="8,6,8,0" ColumnSpacing="4">
        <DatePicker Grid.Column="0"
                    Date="{Binding FechaInicio}"
                    Format="dd/MM/yyyy"
                    VerticalOptions="Center" />
        <Label Grid.Column="1" Text="→"
               VerticalOptions="Center" HorizontalOptions="Center" Margin="4,0"/>
        <DatePicker Grid.Column="2"
                    Date="{Binding FechaFin}"
                    Format="dd/MM/yyyy"
                    VerticalOptions="Center" />
        <Button Grid.Column="3"
                Text="{Binding IconoOrden}"
                Command="{Binding ToggleOrdenCommand}"
                FontSize="18"
                BackgroundColor="Transparent"
                WidthRequest="40"
                VerticalOptions="Center" />
      </Grid>

      <!-- Picker de categoría -->
      <Picker Grid.Row="2"
              ItemsSource="{Binding TiposFiltro}"
              SelectedItem="{Binding FiltroTipo}"
              Title="Filtrar por tipo"
              Margin="8,4,8,4" />

      <!-- Lista agrupada -->
      <CollectionView Grid.Row="3"
                      ItemsSource="{Binding ElementosAgrupados}"
                      IsGrouped="True"
                      SelectionMode="Single"
                      SelectionChangedCommand="{Binding ItemSelectedCommand}"
                      Margin="0,4,0,0">

        <!-- Encabezado de grupo -->
        <CollectionView.GroupHeaderTemplate>
          <DataTemplate x:DataType="vm:HistorialGroup">
            <Grid Padding="12,8,12,4" BackgroundColor="{DynamicResource SurfaceColor}">
              <Label>
                <Label.FormattedText>
                  <FormattedString>
                    <Span Text="{Binding Icono}" FontSize="16" />
                    <Span Text="  " />
                    <Span Text="{Binding Nombre}" FontAttributes="Bold" FontSize="15" />
                    <Span Text="  (" />
                    <Span Text="{Binding Cantidad}" />
                    <Span Text=")" TextColor="Gray" FontSize="13"/>
                  </FormattedString>
                </Label.FormattedText>
              </Label>
            </Grid>
          </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <!-- Ítem -->
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="vm:HistorialItem">
            <Grid Padding="12,8" ColumnDefinitions="40,*,Auto">
              <Label Grid.Column="0" Text="{Binding Icono}" FontSize="22" VerticalOptions="Center"/>
              <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding Titulo}" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                <Label Text="{Binding Descripcion}" FontSize="12" TextColor="Gray" LineBreakMode="TailTruncation"/>
              </StackLayout>
              <StackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                <Label Text="{Binding FechaCorta}" FontSize="11" TextColor="Gray" HorizontalOptions="End"/>
                <Label Text="{Binding Tipo}" FontSize="10" TextColor="{Binding Color}" HorizontalOptions="End"/>
              </StackLayout>
            </Grid>
          </DataTemplate>
        </CollectionView.ItemTemplate>

        <!-- Pie de grupo (separador) -->
        <CollectionView.GroupFooterTemplate>
          <DataTemplate x:DataType="vm:HistorialGroup">
            <BoxView HeightRequest="1" Color="{DynamicResource SeparatorColor}" Margin="12,0"/>
          </DataTemplate>
        </CollectionView.GroupFooterTemplate>

      </CollectionView>

    </Grid>
  </ContentPage.Content>
</ContentPage>
