<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CajaApp.Views.NotaEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:CajaApp.Helpers;assembly=Sellik"
    Title="{loc:Translate NotaEditor_Titulo}"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <ScrollView>
        <StackLayout Padding="20">

            <!--  Header con tipo de nota  -->
            <Border
                Margin="0,0,0,20"
                Padding="15"
                BackgroundColor="#9C27B0"
                StrokeShape="RoundRectangle 10"
                Stroke="Transparent">
                <StackLayout HorizontalOptions="Center" Orientation="Horizontal">
                    <Label
                        x:Name="TipoNotaLabel"
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="📝 Nueva Nota de Texto"
                        TextColor="White" />
                </StackLayout>
            </Border>
            <Label
                Margin="0,10,0,5"
                FontAttributes="Bold"
                FontSize="14"
                Text="Título" />
            <Entry
                x:Name="TituloEntry"
                Margin="0,0,0,15"
                FontSize="16"
                Placeholder="Ingresa un título para tu nota..." />

            <!--  Fecha  -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackLayout Grid.Column="0" Margin="0,0,10,0">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Fecha" />
                    <DatePicker x:Name="FechaPicker" />
                </StackLayout>

                <StackLayout Grid.Column="1" Margin="10,0,0,0">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Hora" />
                    <TimePicker x:Name="HoraPicker" />
                </StackLayout>
            </Grid>

            <!--  Etiquetas  -->
            <Label
                Margin="0,0,0,5"
                FontAttributes="Bold"
                FontSize="14"
                Text="Etiquetas (separadas por comas)" />
            <Entry
                x:Name="EtiquetasEntry"
                Margin="0,0,0,15"
                FontSize="14"
                Placeholder="trabajo, personal, importante..." />

            <!--  Favorita  -->
            <StackLayout Margin="0,0,0,15" Orientation="Horizontal">
                <CheckBox x:Name="FavoritaCheckBox" Color="#FFD700" />
                <Label
                    FontSize="14"
                    Text="⭐ Marcar como favorita"
                    TextColor="#FFD700"
                    VerticalOptions="Center" />
            </StackLayout>

            <!--  Contenido de texto  -->
            <Label
                x:Name="ContenidoLabel"
                Margin="0,10,0,5"
                FontAttributes="Bold"
                FontSize="14"
                IsVisible="True"
                Text="Contenido" />
            <Editor
                x:Name="ContenidoEditor"
                Margin="0,0,0,15"
                AutoSize="TextChanges"
                FontSize="14"
                HeightRequest="200"
                IsVisible="True"
                Placeholder="Escribe el contenido de tu nota aquí..." />

            <!--  Sección de imagen  -->
            <StackLayout x:Name="ImagenSection" IsVisible="False">
                <Label
                    Margin="0,0,0,10"
                    FontAttributes="Bold"
                    FontSize="14"
                    Text="Imagen" />

                <!--  Botones de captura  -->
                <StackLayout
                    Margin="0,0,0,15"
                    HorizontalOptions="Fill"
                    Orientation="Horizontal">
                    <Button
                        x:Name="TomarFotoButton"
                        BackgroundColor="#4CAF50"
                        Clicked="OnTomarFotoClicked"
                        CornerRadius="8"
                        FontSize="14"
                        HorizontalOptions="Fill"
                        Text="📷 Tomar Foto"
                        TextColor="White" />

                    <Button
                        x:Name="SeleccionarImagenButton"
                        Margin="10,0,0,0"
                        BackgroundColor="#2196F3"
                        Clicked="OnSeleccionarImagenClicked"
                        CornerRadius="8"
                        FontSize="14"
                        HorizontalOptions="Fill"
                        Text="🖼️ Galería"
                        TextColor="White" />
                </StackLayout>

                <!--  Vista previa de imagen  -->
                <Border
                    x:Name="ImagenFrame"
                    Margin="0,0,0,15"
                    Padding="10"
                    BackgroundColor="{DynamicResource SurfaceColor}"
                    StrokeShape="RoundRectangle 10"
                    Stroke="Transparent"
                    IsVisible="False">
                    <StackLayout>
                        <Image
                            x:Name="ImagenPreview"
                            Aspect="AspectFit"
                            HeightRequest="200" />
                        <Button
                            x:Name="EliminarImagenButton"
                            Margin="0,10,0,0"
                            BackgroundColor="#F44336"
                            Clicked="OnEliminarImagenClicked"
                            CornerRadius="5"
                            FontSize="12"
                            Text="🗑️ Eliminar Imagen"
                            TextColor="White" />
                    </StackLayout>
                </Border>
            </StackLayout>

            <!--  Botones de acción  -->
            <StackLayout Margin="0,30,0,0" Orientation="Horizontal">
                <Button
                    x:Name="CancelarButton"
                    BackgroundColor="#F44336"
                    Clicked="OnCancelarClicked"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    FontSize="14"
                    HorizontalOptions="Fill"
                    Text="{loc:Translate Btn_Cancelar}"
                    TextColor="White" />

                <Button
                    x:Name="GuardarButton"
                    Margin="15,0,0,0"
                    BackgroundColor="#4CAF50"
                    Clicked="OnGuardarClicked"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    FontSize="14"
                    HorizontalOptions="Fill"
                    Text="{loc:Translate Btn_Guardar}"
                    TextColor="White" />
            </StackLayout>

        </StackLayout>
    </ScrollView>
</ContentPage>